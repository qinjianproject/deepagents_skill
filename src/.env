# Tavily API Key for web search (primary)
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=xxx

# SearXNG URL for fallback search (optional)
# Example: http://localhost:8080
SEARXNG_URL=

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# OpenAI Base URL (optional, default: https://api.openai.com/v1)
OPENAI_BASE_URL=xxx

# OpenAI Model (optional, default: gpt-4o-mini)
OPENAI_MODEL=xxx

# Agent Recursion Limit (optional, default: 25)
RECURSION_LIMIT=25


MAX_CLUE_GET=20